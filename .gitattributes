# Einheitliche Zeilenenden ueber alle Plattformen (Multiplattform-Repo):
# Textdateien immer mit LF im Repo, unabhaengig vom Checkout-OS.
* text=auto eol=lf

# Explizit Text
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf

# Binaerdateien nie normalisieren
*.png   binary
*.wav   binary
*.dll   binary
*.dylib binary
*.so    binary
